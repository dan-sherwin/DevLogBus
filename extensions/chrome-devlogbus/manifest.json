{
  "manifest_version": 3,
  "name": "DevLogBus Browser Tap",
  "description": "Sends Chrome console, runtime, log, and network events into your local DevLogBus stream.",
  "version": "1.3.2",
  "minimum_chrome_version": "125",
  "permissions": ["activeTab", "debugger", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "DevLogBus Browser Tap",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
